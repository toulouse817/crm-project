APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# --- LOGGING ---
# Local: stack / Vercel: stderr
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- DATABASE ---
# Local: sqlite or mysql / Production Vercel: mysql or pgsql serverless (Neon, Supabase, AWS RDS, etc.)
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# --- SESSIONS ---
# Local: database or file / Production Vercel: cookie or redis
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --- CACHE ---
# Local: database or file / Production Vercel: array or redis
CACHE_STORE=database
# CACHE_PREFIX=

# --- FILESYSTEM / STORAGE ---
# Local: local / Production Vercel: s3 (since Vercel is read-only)
FILESYSTEM_DISK=local

# --- QUEUES ---
# Local: database or sync / Production Vercel: sync or database/sqs (requires worker daemon elsewhere)
QUEUE_CONNECTION=sync

# --- REDIS (Optional for production session/cache/queues) ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- MAIL ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS S3 (Critical for file storage on Vercel) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- VITE ---
VITE_APP_NAME="${APP_NAME}"
